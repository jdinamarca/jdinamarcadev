---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { SITE } from "../consts";
---

<BaseLayout
  title="Contacto"
  description={`Contacta con ${SITE.author}. Arquitectura, consultoría técnica y divulgación.`}
>
  <section class="shell section">
    <SectionHeading index="§06" label="Canal abierto" title="Contacto" />

    <div class="contact-grid">
      <div class="contact-intro">
        <p class="lead">
          ¿Construyes un sistema que necesita claridad? Cuéntame el problema antes
          que la solución —la mejor conversación empieza por ahí.
        </p>
        <p class="contact-aside">
          Respondo en 24–48 h hábiles. Para temas de consultoría, incluye contexto
          del equipo y la escala.
        </p>

        <ul class="contact-channels">
          <li>
            <span class="label">Correo</span>
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          {
            SITE.social.map((s) => (
              <li>
                <span class="label">{s.label}</span>
                <a href={s.href} target="_blank" rel="noopener me">
                  {s.href.replace(/^https?:\/\//, "").replace(/\/$/, "")}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <form class="contact-form" method="POST" action={SITE.email} data-contact-form novalidate>
        <p class="label">Formulario</p>
        <div class="field">
          <label for="name">Nombre</label>
          <input id="name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="email">Correo</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="subject">Asunto</label>
          <input id="subject" name="subject" type="text" />
        </div>
        <div class="field">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="gotcha" />
        <div class="form-actions">
          <button class="btn-signal" type="submit">
            Enviar mensaje <span aria-hidden="true">→</span>
          </button>
          <p class="form-status" data-form-status aria-live="polite"></p>
        </div>
        <noscript>
          <p class="form-noscript">
            Este formulario usa tu cliente de correo. Si prefieres, escribe
            directamente a <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
          </p>
        </noscript>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: clamp(2rem, 1rem + 4vw, 4.5rem);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-top: 1rem;
  }
  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }
  .contact-aside {
    color: var(--color-ink-soft);
    max-width: 42ch;
    margin-top: 1.5rem;
  }
  .contact-channels {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
  }
  .contact-channels li {
    background: var(--color-paper);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .contact-channels a {
    text-decoration: none;
    color: var(--color-ink);
    word-break: break-all;
  }
  .contact-channels a:hover {
    color: var(--color-signal-deep);
  }

  .contact-form {
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
    padding: clamp(1.25rem, 1rem + 1.5vw, 2rem);
  }
  .contact-form > .label {
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-line);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.1rem;
  }
  .field label {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-ink-soft);
  }
  .field input,
  .field textarea {
    font: inherit;
    color: var(--color-ink);
    background: var(--color-concrete);
    border: 1px solid var(--color-line);
    padding: 0.7rem 0.8rem;
    border-radius: var(--radius-xs);
    transition: border-color 0.15s var(--ease-blueprint);
  }
  .field input:focus-visible,
  .field textarea:focus-visible {
    border-color: var(--color-ink);
  }
  .gotcha {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .form-status {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .form-status[data-state="ok"] {
    color: var(--color-signal-deep);
  }
  .form-status[data-state="error"] {
    color: var(--color-ink);
  }
  .form-noscript {
    margin-top: 1rem;
    font-size: var(--text-meta);
    color: var(--color-ink-soft);
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLElement>("[data-form-status]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function setStatus(text: string, ok: boolean | null = null) {
    if (!status) return;
    status.textContent = text;
    status.dataset.state = ok === null ? "loading" : ok ? "ok" : "error";
  }

  function mailtoFallback() {
    if (!form) return;
    const data = new FormData(form);
    const name = String(data.get("name") ?? "");
    const email = String(data.get("email") ?? "");
    const subject = String(data.get("subject") ?? "Contacto desde el sitio");
    const message = String(data.get("message") ?? "");
    const to = form.getAttribute("action") ?? "";
    const body = `${message}\n\n— ${name} (${email})`;
    window.location.href = `mailto:${to}?subject=${encodeURIComponent(
      subject,
    )}&body=${encodeURIComponent(body)}`;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const payload = {
      name: String(data.get("name") ?? ""),
      email: String(data.get("email") ?? ""),
      subject: String(data.get("subject") ?? ""),
      message: String(data.get("message") ?? ""),
      _gotcha: String(data.get("_gotcha") ?? ""),
    };

    setStatus("Enviando…", null);
    const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]");
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const json = (await res.json().catch(() => ({}))) as {
        ok?: boolean;
        error?: string;
        fields?: Record<string, string>;
      };

      if (res.ok && json.ok) {
        setStatus("Mensaje enviado. Gracias.", true);
        form.reset();
      } else if (res.status >= 500) {
        setStatus("Servicio no disponible. Abriendo tu cliente de correo…", false);
        mailtoFallback();
      } else {
        const fieldErr = json.fields ? Object.values(json.fields)[0] : null;
        setStatus(fieldErr ?? json.error ?? "Revisa los campos.", false);
      }
    } catch {
      setStatus("Sin conexión. Abriendo tu cliente de correo…", false);
      if (!reduce) mailtoFallback();
      else setStatus("Sin conexión. Reintenta más tarde.", false);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
