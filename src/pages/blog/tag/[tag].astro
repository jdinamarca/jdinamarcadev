---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const slugifyTag = (t: string) =>
    t
      .toLowerCase()
      .normalize("NFKD")
      .replace(/\p{M}+/gu, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-+|-+$)/g, "");

  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const cap = tag.charAt(0).toUpperCase() + tag.slice(1);
const total = posts.length;
---

<BaseLayout
  title={`Tema: ${cap} — Blog`}
  description={`Publicaciones filtradas por el tema «${cap}».`}
>
  <section class="shell section">
    <a href="/blog" class="tagbar__back">← Blog</a>
    <SectionHeading
      index="§02 · tema"
      label="Tema"
      title={cap}
    />
    <p class="lede tagpage-lede">
      {total} {total === 1 ? "publicación" : "publicaciones"} etiquetadas con
      <strong>{cap}</strong>.
    </p>

    <ul class="bloglist">
      {
        posts.map((post, i) => (
          <li class="bloglist__item">
            <a href={`/blog/${post.id}`} class="bloglist__link group">
              <div class="bloglist__content">
                <div class="bloglist__row bloglist__row--top">
                  <span class="bloglist__no">
                    {String(posts.length - i).padStart(2, "0")}
                  </span>
                  <span class="draw-rule bloglist__rule" aria-hidden="true" />
                  <span class="bloglist__date">
                    <FormattedDate date={post.data.pubDate} format="short" />
                  </span>
                </div>
                <div class="bloglist__row bloglist__row--main">
                  <h2 class="bloglist__title">{post.data.title}</h2>
                  <span class="bloglist__arrow" aria-hidden="true">→</span>
                </div>
                <p class="bloglist__desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="bloglist__tags">
                    {post.data.tags.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                )}
              </div>
              {post.data.heroImage && (
                <div class="bloglist__media" aria-hidden="true">
                  <img
                    src={post.data.heroImage}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: clamp(2rem, 1rem + 4vw, 4.5rem);
  }
  .tagbar__back {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-ink-soft);
  }
  .tagbar__back:hover {
    color: var(--color-signal-deep);
  }
  .tagpage-lede {
    max-width: 60ch;
    margin: 0 0 2.5rem;
  }

  .bloglist {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-ink);
  }
  .bloglist__item {
    border-bottom: 1px solid var(--color-line);
  }
  .bloglist__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1.5rem 0;
    text-decoration: none;
    color: var(--color-ink);
  }
  @media (min-width: 720px) {
    .bloglist__link {
      grid-template-columns: 1fr auto;
    }
  }
  .bloglist__media {
    width: clamp(140px, 22vw, 200px);
    aspect-ratio: 8 / 5;
    border: 1px solid var(--color-line);
    background: var(--color-paper);
    overflow: hidden;
  }
  .bloglist__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-blueprint);
  }
  .group:hover .bloglist__media img {
    transform: scale(1.04);
  }
  .bloglist__row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .bloglist__row--top {
    margin-bottom: 0.5rem;
  }
  .bloglist__no {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--color-signal);
    flex: none;
  }
  .bloglist__rule {
    flex: 1;
    height: 1px;
    background: var(--color-ink);
    opacity: 0.2;
    transform: scaleX(0.3);
    transform-origin: left;
    transition: transform 0.45s var(--ease-blueprint), opacity 0.45s var(--ease-blueprint);
  }
  .group:hover .bloglist__rule {
    transform: scaleX(1);
    opacity: 1;
  }
  .bloglist__date {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--color-ink-faint);
    flex: none;
  }
  .bloglist__row--main {
    justify-content: space-between;
  }
  .bloglist__title {
    font-size: var(--text-h2);
    margin: 0;
    transition: color 0.2s var(--ease-blueprint);
  }
  .group:hover .bloglist__title {
    color: var(--color-signal-deep);
  }
  .bloglist__arrow {
    font-family: var(--font-mono);
    color: var(--color-ink-faint);
    transition: transform 0.2s var(--ease-blueprint), color 0.2s var(--ease-blueprint);
  }
  .group:hover .bloglist__arrow {
    transform: translateX(5px);
    color: var(--color-signal);
  }
  .bloglist__desc {
    color: var(--color-ink-soft);
    margin: 0.75rem 0 0;
    max-width: 60ch;
  }
  .bloglist__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.9rem 0 0;
    padding: 0;
  }
  .bloglist__tags li {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--color-ink-faint);
  }
  .bloglist__tags li::before {
    content: "#";
    color: var(--color-signal);
    margin-right: 0.1rem;
  }
</style>
